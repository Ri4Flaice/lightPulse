# Required: admin password (>= 4 chars)
ADMIN_PASSWORD=changeme

# Required: HMAC secret used to sign session cookies (any random string >= 32 chars)
ADMIN_COOKIE_SECRET=replace-with-random-32+char-string

# Optional: custom URL path for admin panel (default: /admin)
# Must start with "/" and not collide with /api or /_next
ADMIN_PATH=/admin
